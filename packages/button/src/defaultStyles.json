{
  "container": {
    "background": {
      "color": {
        "$*": "#FFFFFF",
        "$dark": "#000000"
      },
      "gradient": {
        "$base": {
          "direction": "vertical",
          "colors": [
            "#D9D9D9",
            "#FFFFFF",
            "#BFBFBF"
          ]
        }
      },
      "padding": {
        "$*": 4,
        "$avatar": 15,
        "$vertical": 8
      },
      "width": {
        "$*": 200,
        "$avatar": 150,
        "$vertical": 60
      },
      "height": {
        "$*": 40,
        "$avatar": 150,
        "$vertical": 80
      }
    },
    "content": {
      "gap": {
        "$*": 6,
        "$vertical": 4,
        "$avatar": 8
      }
    },
    "border": {
      "width": {
        "$*": 1,
        "$avatar": 0
      },
      "color": {
        "$*": "#000000",
        "$dark": "#FFFFFF"
      },
      "radius": {
        "$*": 10,
        "$avatar": 100
      }
    }
  },
  "label": {
    "font": {
      "$*": [
        "Helvetica",
        "Arial",
        "sans-serif"
      ],
      "alpha": {
        "$*": 1,
        "$disabled": 0.45
      },
      "color": {
        "$*": "#000000",
        "$dark": "#FFFFFF"
      }
    },
    "size": {
      "$*": 14,
      "$avatar": 24
    }
  },
  "icon": {
    "alpha": {
      "$*": 1,
      "$disabled": 0.45
    },
    "size": {
      "width": {
        "$*": 16,
        "$avatar": 24
      },
      "height": {
        "$*": 16,
        "$avatar": 24
      },
      "size": {
        "$*": 16,
        "$avatar": 24
      }
    }
  }
}
